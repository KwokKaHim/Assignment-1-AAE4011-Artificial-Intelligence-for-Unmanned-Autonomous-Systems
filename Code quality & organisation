#!/usr/bin/env python3
import rospy
import os
import cv2
import threading
from sensor_msgs.msg import CompressedImage
from std_msgs.msg import String
from cv_bridge import CvBridge
from ultralytics import YOLO

os.environ["YOLO_OFFLINE"] = "True"

class VehicleDetector:
    def __init__(self):
        rospy.loginfo("--- 啟動流暢優化版偵測器 (YOLOv8 Nano) ---")
        self.model = YOLO("yolov8n.pt")  
        self.bridge = CvBridge()
        self.lock = threading.Lock()
        self.image_sub = rospy.Subscriber(
            "/hikcamera/image_2/compressed", 
            CompressedImage, 
            self.callback,
            queue_size=1,
            buff_size=2**24
        )

        self.image_pub = rospy.Publisher(
            "/vehicle_detection/image/compressed", CompressedImage, queue_size=1
        )

        self.meta_pub = rospy.Publisher("/vehicle_detection/meta", String, queue_size=1)

    def callback(self, msg):
        if not self.lock.acquire(False):
            return

        try:
            frame = self.bridge.compressed_imgmsg_to_cv2(msg, "bgr8")
            h, w = frame.shape[:2]
            scale = 480.0 / h
            small_frame = cv2.resize(frame, (int(w * scale), 480))

            results = self.model(small_frame, conf=0.25, verbose=False, imgsz=480)
            result = results[0]

            annotated_frame = result.plot()

            ros_img = self.bridge.cv2_to_compressed_imgmsg(annotated_frame, dst_format="jpg")
            ros_img.header = msg.header
            
            self.image_pub.publish(ros_img)
            self.meta_pub.publish(result.to_json())

        except Exception as e:
            rospy.logerr(f"偵測異常: {e}")
        finally:
            self.lock.release()

if __name__ == "__main__":
    rospy.init_node("vehicle_detector", anonymous=True)
    try:
        vd = VehicleDetector()
        rospy.loginfo("偵測節點已就緒。")
        rospy.spin()
    except rospy.ROSInterruptException:
        pass
